# ===========================================================================
# AURA Command Center — environment variables
# Copy to .env.local for local dev; set the same vars in Vercel for prod.
# NEVER commit real values. NEXT_PUBLIC_* vars are exposed to the browser —
# everything else stays server-side.
# ===========================================================================

# --- Supabase (docs/supabase-setup.md) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key: server-only, bypasses RLS. Required for the Shortcuts
# endpoint and audit logging.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Single-user lock --------------------------------------------------------
# Only this email can use AURA, even with a valid Supabase session.
ALLOWED_EMAIL=you@example.com

# --- LLM ---------------------------------------------------------------------
# Provider: anthropic (default). Add more in lib/ai/index.ts.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-opus-4-8)
# AURA_MODEL=claude-opus-4-8

# --- Apple Shortcuts ---------------------------------------------------------
# Personal API key for POST /api/shortcut/command. Generate something long:
#   openssl rand -hex 32
SHORTCUT_API_KEY=
