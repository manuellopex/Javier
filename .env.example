# ===========================================================================
# AURA Command Center — environment variables
# Copy to .env.local for local dev; set the same vars in Vercel for prod.
# NEVER commit real values. NEXT_PUBLIC_* vars are exposed to the browser —
# everything else stays server-side.
# ===========================================================================

# --- Supabase (docs/supabase-setup.md) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key: server-only, bypasses RLS. Required for the Shortcuts
# endpoint and audit logging.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Single-user lock --------------------------------------------------------
# Only this email can use AURA, even with a valid Supabase session.
ALLOWED_EMAIL=you@example.com

# --- LLM ---------------------------------------------------------------------
# Provider: anthropic (default). Add more in lib/ai/index.ts.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-opus-4-8)
# AURA_MODEL=claude-opus-4-8

# --- Voice (Fase 2 — all optional; browser voice works without these) -------
# Speech-to-text for /api/transcribe. Pick one (or set STT_PROVIDER to force):
#   STT_PROVIDER=deepgram | groq
# DEEPGRAM_API_KEY=
# GROQ_API_KEY=
# Text-to-speech for /api/tts (premium spoken replies; falls back to browser):
#   TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=          # default: Rachel (21m00Tcm4TlvDq8ikWAM)
# ELEVENLABS_MODEL=             # default: eleven_multilingual_v2

# --- Integrations (Fase 3 — all optional; docs/integrations.md) -------------
# Google Calendar OAuth (read + create events; delete with confirmation):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Email sending via Resend (drafts are free; SENDING always needs your
# confirmation in the Commands view):
# RESEND_API_KEY=
# EMAIL_FROM="AURA <aura@tudominio.com>"   # verified sender on Resend

# --- Apple Shortcuts ---------------------------------------------------------
# Personal API key for POST /api/shortcut/command. Generate something long:
#   openssl rand -hex 32
SHORTCUT_API_KEY=
